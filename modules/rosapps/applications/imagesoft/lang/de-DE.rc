STRINGTABLE DISCARDABLE
BEGIN
  IDS_HINT_BLANK        " "
  IDS_HINT_NEW          " Erstellt ein neues Dokument."
  IDS_HINT_OPEN         " Öffnet ein vorhandenes Dokument."
  IDS_HINT_CLOSE        " Schließt dieses Fenster."
  IDS_HINT_CLOSEALL     " Schließt alle Fenster."
  IDS_HINT_SAVE         " Speichert das aktive Dokument."
  IDS_HINT_SAVEAS       " Speichert das aktive Dokument unter einem neuen Namen."
  IDS_HINT_PRINTPRE     " Voransicht des gedruckten Dokumentes."
  IDS_HINT_PRINT        " Druckt das aktive Dokument."
  IDS_HINT_PROP         " Zeigt die Eigenschaften des aktiven Bildes."
  IDS_HINT_EXIT         " Beendet das Programm."

  IDS_HINT_TOOLS        " Shows or hides the tools floating window."
  IDS_HINT_COLORS       " Shows or hides the colors floating window."
  IDS_HINT_HISTORY      " Shows or hides the history floating window."
  IDS_HINT_STATUS       " Zeigt oder versteckt die Statusleiste."

  IDS_HINT_CASCADE      " Ordnet die Fenster so an, dass sie überlappen."
  IDS_HINT_TILE_HORZ    " Ordnet die Fenster so an, dass sie nicht-überlappen."
  IDS_HINT_TILE_VERT    " Ordnet die Fenster so an, dass sie nicht-überlappen."
  IDS_HINT_ARRANGE      " Ordnet Symbole am Fuß des Fensters an."
  IDS_HINT_NEXT         " Aktiviert das nächste Fenster."

  IDS_HINT_SYS_RESTORE  " Stellt die Normalgröße dieses Fensters wieder her."
  IDS_HINT_SYS_MOVE     " Verschiebt dieses Fenster."
  IDS_HINT_SYS_SIZE     " Ändert die Größe dieses Fensters."
  IDS_HINT_SYS_MINIMIZE " Minimiert dieses Fenster zu einem Symbol."
  IDS_HINT_SYS_MAXIMIZE " Maximiert dieses Fenster auf Bildschirmgröße."
END
