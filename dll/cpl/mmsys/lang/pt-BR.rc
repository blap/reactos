IDD_SETUP1 DIALOGEX 0, 0, 227, 206
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUPWINDOW | WS_VISIBLE | WS_CAPTION
CAPTION "Setup"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Áudio do ReactOS", 10243, 7, 5, 213, 192
    ICON 4393, 10241, 26, 26, 20, 20
    LTEXT "Este computador não pode reproduzir áudio porque o serviço de áudio do ReactOS não está ativado.", 10245, 60, 25, 150, 40
    AUTOCHECKBOX "&Ativar o áudio do ReactOS", 10253, 60, 68, 150, 9
    LTEXT "Observações", 10246, 58, 87, 150, 11
    LTEXT "1. você deve ser um administrador para habilitar esse serviço. Se você não fez login como administrador, você será solicitado um nome de administrador e senha.", 10247, 60, 100, 150, 40
    LTEXT "2. Depois que você ativar o áudio ReactOS você terá que reiniciar o computador.", 10248, 60, 140, 150, 40
END

