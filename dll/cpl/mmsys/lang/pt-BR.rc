LANGUAGE LANG_PORTUGUESE, SUBLANG_PORTUGUESE_BRAZILIAN

IDD_VOLUME DIALOGEX 0, 0, 246, 228
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Volume"
FONT 8, "MS Shell Dlg"
BEGIN
    ICON IDI_CPLICON, IDI_CPLICON, 8, 5, 32, 32
    LTEXT "", IDC_DEVICE_NAME, 40, 10, 194, 20
    GROUPBOX "Volume de dispositivo", -1, 7, 30, 230, 100
    CONTROL "", IDC_MUTE_ICON, "Static", SS_ICON | WS_VISIBLE, 17, 45, 32, 32
    CONTROL "", IDC_VOLUME_TRACKBAR, "msctls_trackbar32", TBS_AUTOTICKS | TBS_ENABLESELRANGE | TBS_BOTTOM | TBS_HORZ | WS_TABSTOP, 65, 45, 140, 14
    LTEXT "Baixa", -1, 62, 66, 30, 9
    LTEXT "Alta", -1, 195, 66, 30, 9
    AUTOCHECKBOX "&Mudo", IDC_MUTE_CHECKBOX, 50, 78, 140, 10
    AUTOCHECKBOX "Coloque o í&cone de volume na barra de tarefas", IDC_ICON_IN_TASKBAR, 50, 92, 140, 10
    PUSHBUTTON "Ava&nçadas...", IDC_ADVANCED_BTN, 150, 105, 75, 15
    GROUPBOX "Configurações de caixas de som", IDC_SPEAKER_SET_BTN, 7, 140, 230, 80
    CONTROL "", IDC_SPEAKIMG, "Static", SS_OWNERDRAW, 4, 155, 70, 70
    LTEXT "Use as configurações abaixo para alterar o volume de cada caixa de som e outras configurações.", -1, 70, 155, 150, 36
    PUSHBUTTON "&Volume das caixas de som...", IDC_SPEAKER_VOL_BTN, 70, 195, 75, 15
    PUSHBUTTON "Ava&nçada...", IDC_ADVANCED2_BTN, 150, 195, 75, 15
END

IDD_SOUNDS DIALOGEX 0, 0, 246, 228
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Sons"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Um esquema de som é um conjunto de sons aplicados a eventos no ReactOS e nos programas. Você pode selecionar um esquema existente ou salvar um que você modificou.", -1, 8, 7, 230, 30
    LTEXT "Sound s&cheme:", -1, 8, 42, 150, 9
    COMBOBOX IDC_SOUND_SCHEME, 8, 53, 230, 46, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON "Salv&ar Como...", IDC_SAVEAS_BTN, 134, 70, 50, 15
    PUSHBUTTON "&Apagar", IDC_DELETE_BTN, 188, 70, 50, 15
    LTEXT "Para alterar sons, clique em um evento do programa na lista e em seguida, selecione um som para aplicar. Você pode salvar as alterações como um novo esquema de som.", -1, 8, 90, 230, 27
    LTEXT "&Eventos de programa:", -1, 8, 118, 150, 9
    CONTROL "", IDC_SCHEME_LIST, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | LVS_SORTASCENDING | WS_BORDER | WS_TABSTOP, 8, 130, 230, 60, WS_EX_CLIENTEDGE
    LTEXT "&Sons:", IDC_TEXT_SOUND, 8, 194, 80, 9, WS_DISABLED
    COMBOBOX IDC_SOUND_LIST, 8, 205, 155, 146, CBS_DROPDOWNLIST | CBS_DISABLENOSCROLL | CBS_SORT | WS_VSCROLL | WS_TABSTOP | WS_DISABLED
    PUSHBUTTON "", IDC_PLAY_SOUND, 168, 205, 15, 15, WS_DISABLED | BS_ICON
    PUSHBUTTON "&Browse...", IDC_BROWSE_SOUND, 188, 205, 50, 15, WS_DISABLED
END

IDD_AUDIO DIALOGEX 0, 0, 246, 228
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Áudio"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Reprodução de som", -1, 7, 7, 230, 60
    ICON IDI_CPLICON, IDI_CPLICON, 15, 20, 32, 32
    LTEXT "&Dispositivo padrão:", -1, 50, 20, 80, 9
    COMBOBOX IDC_DEVICE_PLAY_LIST, 50, 30, 180, 46, CBS_DROPDOWNLIST
    PUSHBUTTON "&Volume...", IDC_VOLUME1_BTN, 85, 47, 70, 15
    PUSHBUTTON "Avan&çado...", IDC_ADV2_BTN, 160, 47, 70, 15
    GROUPBOX "Gravação de som", -1, 7, 75, 230, 60
    ICON IDI_MICROPHONE_ICON, IDI_MICROPHONE_ICON, 15, 88, 32, 32
    LTEXT "D&ispositivo padrão:", -1, 50, 88, 80, 9
    COMBOBOX IDC_DEVICE_REC_LIST, 50, 98, 180, 46, CBS_DROPDOWNLIST
    PUSHBUTTON "V&olume...", IDC_VOLUME2_BTN, 85, 115, 70, 15
    PUSHBUTTON "Avança&do...", IDC_ADV1_BTN, 160, 115, 70, 15
    GROUPBOX "MIDI music playback", -1, 7, 145, 230, 60
    ICON IDI_MIDICON, IDI_MIDICON, 15, 158, 32, 32
    LTEXT "De&fault device:", -1, 50, 158, 80, 9
    COMBOBOX IDC_DEVICE_MIDI_LIST, 50, 168, 180, 46, CBS_DROPDOWNLIST
    PUSHBUTTON "Volu&me...", IDC_VOLUME3_BTN, 85, 185, 70, 15
    PUSHBUTTON "So&bre...", IDC_ADV3_BTN, 160, 185, 70, 15
    AUTOCHECKBOX "&Usar apenas dispositivos padrão", IDC_DEFAULT_DEV_CHECKBOX, 7, 212, 140, 10
END

IDD_VOICE DIALOGEX 0, 0, 246, 228
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Voz"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Essas configurações controlam o volume e opções avançadas para os dispositivos de reprodução de voz ou de gravação selecionado.", -1, 8, 7, 230, 40
    GROUPBOX "Reprodução de voz", -1, 7, 37, 230, 60
    ICON IDI_CPLICON, IDI_CPLICON, 15, 50, 32, 32
    LTEXT "&Dispositivo padrão:", -1, 50, 50, 80, 9
    COMBOBOX IDC_DEVICE_VOICE_LIST, 50, 60, 180, 46, CBS_DROPDOWNLIST
    PUSHBUTTON "&Volume...", IDC_VOLUME4_BTN, 85, 77, 70, 15
    PUSHBUTTON "Avan&çado...", IDC_ADV4_BTN, 160, 77, 70, 15
    GROUPBOX "Gravação de voz", -1, 7, 105, 230, 60
    ICON IDI_MICROPHONE_ICON, IDI_MICROPHONE_ICON, 15, 118, 32, 32
    LTEXT "D&ispositivo padrão:", -1, 50, 118, 80, 9
    COMBOBOX IDC_DEVICE_VOICE_REC_LIST, 50, 128, 180, 46, CBS_DROPDOWNLIST
    PUSHBUTTON "V&olume...", IDC_VOLUME5_BTN, 85, 145, 70, 15
    PUSHBUTTON "Avança&do...", IDC_ADV5_BTN, 160, 145, 70, 15
    PUSHBUTTON "&Test hardware...", IDC_TEST_HARDWARE, 160, 175, 70, 15
END

