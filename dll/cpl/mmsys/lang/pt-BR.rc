IDD_SETUP2 DIALOGEX 0, 0, 227, 206
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUPWINDOW | WS_VISIBLE | WS_CAPTION
CAPTION "Setup"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Áudio do ReactOS", 10259, 7, 5, 213, 192
    ICON 4394, 10257, 25, 25, 20, 20
    LTEXT "O serviço de áudio do ReactOS está habilitado. Entretanto, áudio pode não funcionar corretamente até que você reinicie o ReactOS. Se você deseja reiniciar agora, primeiro salve o trabalho e feche todos os programas.", 10261, 60, 25, 150, 50
    LTEXT "Para reiniciar o ReactOS, clique OK.", 10262, 60, 75, 150, 20
    LTEXT "Se você Cancelar, você precisará reiniciar mais tarde para o que o áudio ReactOS funcione corretamente.", 10263, 60, 100, 150, 40
END

