IDD_SETUP2 DIALOGEX 0, 0, 227, 206
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUPWINDOW | WS_VISIBLE | WS_CAPTION
CAPTION "Mempersiapkan"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Audio ReactOS", 10259, 7, 5, 213, 192
    ICON 4394, 10257, 25, 25, 20, 20
    LTEXT "Layanan ReactOS Audio sekarang diaktifkan. Namun, audio mungkin tidak berfungsi dengan benar sampai Anda me-restart ReactOS. Jika Anda ingin me-restart sekarang, simpan dulu pekerjaan Anda dan tutup semua program.", 10261, 60, 25, 150, 50
    LTEXT "Untuk me-restart ReactOS, klik OK.", 10262, 60, 75, 150, 20
    LTEXT "Jika Anda Batal, Anda perlu memulai ulang nanti agar ReactOS Audio berfungsi dengan benar.", 10263, 60, 100, 150, 40
END

