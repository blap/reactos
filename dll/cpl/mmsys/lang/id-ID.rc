IDD_SETUP1 DIALOGEX 0, 0, 227, 206
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUPWINDOW | WS_VISIBLE | WS_CAPTION
CAPTION "Mempersiapkan"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Audio ReactOS", 10243, 7, 5, 213, 192
    ICON 4393, 10241, 26, 26, 20, 20
    LTEXT "Komputer ini tidak dapat memutar audio karena layanan ReactOS Audio tidak diaktifkan.", 10245, 60, 25, 150, 40
    AUTOCHECKBOX "& Aktifkan ReactOS Audio", 10253, 60, 68, 150, 9
    LTEXT "Catatan", 10246, 58, 87, 150, 11
    LTEXT "1. Anda harus menjadi administrator untuk mengaktifkan layanan ini. Jika Anda tidak masuk sebagai administrator, Anda akan diminta memasukkan nama administrator dan kata sandi.", 10247, 60, 100, 150, 40
    LTEXT "2. Setelah Anda mengaktifkan ReactOS Audio Anda harus me-restart komputer.", 10248, 60, 140, 150, 40
END

