IDD_USERPROFILE DIALOGEX 0, 0, 256, 218
STYLE DS_SHELLFONT | DS_MODALFRAME | DS_CONTEXTHELP | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "Profil pengguna"
FONT 8, "MS Shell Dlg"
BEGIN
    ICON IDI_USERPROF, IDC_STATIC, 6, 11, 16, 16, SS_ICON
    LTEXT "Profil pengguna berisi pengaturan desktop dan informasi lainnya yang terkait dengan login Anda. Profil yang berbeda dapat dibuat di setiap komputer yang Anda gunakan, atau Anda dapat memilih profil jelajah yang sama pada setiap komputer yang Anda gunakan.", IDC_STATIC, 40, 11, 211, 35
    LTEXT "Profil yang tersimpan di komputer ini:", IDC_STATIC, 16, 51, 204, 9
    CONTROL "", IDC_USERPROFILE_LIST, "SysListView32", LVS_REPORT | LVS_SINGLESEL |
            LVS_SHOWSELALWAYS | LVS_SORTASCENDING | WS_BORDER | WS_TABSTOP, 6, 66, 244, 85, WS_EX_CLIENTEDGE
    PUSHBUTTON "Change Type", IDC_USERPROFILE_CHANGE, 90, 156, 50, 13
    PUSHBUTTON "Delete", IDC_USERPROFILE_DELETE, 145, 156, 50, 13
    PUSHBUTTON "Copy To", IDC_USERPROFILE_COPY, 200, 156, 50, 13
    CONTROL "Untuk membuat akun pengguna baru, buka <A> Akun Pengguna </A> di Panel Kontrol.",
            IDC_USERACCOUNT_LINK, "SysLink", WS_CHILD | WS_VISIBLE | WS_TABSTOP, 7, 175, 245, 18
    DEFPUSHBUTTON "Oke", IDOK, 134, 200, 54, 13
    PUSHBUTTON "Membatalkan", IDCANCEL, 196, 200, 54, 13
END

IDD_STARTUPRECOVERY DIALOGEX 6, 18, 252, 280
STYLE DS_SHELLFONT | DS_MODALFRAME | DS_CONTEXTHELP | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "Startup dan Pemulihan"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Sistem startup", IDC_STATIC, 7, 12, 238, 95
    LTEXT "Sistem operasi bawaan:", IDC_STATIC, 14, 26, 100, 8
    COMBOBOX IDC_STRECOSCOMBO, 14, 37, 224, 46, CBS_DROPDOWNLIST | WS_VSCROLL
    AUTOCHECKBOX "& Waktu untuk menampilkan daftar sistem operasi:", IDC_STRECLIST, 14, 56, 160, 8
    EDITTEXT IDC_STRRECLISTEDIT, 185, 54, 30, 12, ES_NUMBER
    CONTROL "", IDC_STRRECLISTUPDWN, "msctls_updown32", UDS_WRAP | UDS_SETBUDDYINT |
            UDS_ALIGNRIGHT | UDS_AUTOBUDDY | UDS_ARROWKEYS | UDS_NOTHOUSANDS | WS_CHILD | WS_VISIBLE, 0, 0, 8, 13
    LTEXT "detik", IDC_STATIC, 223, 56, 18, 8
    AUTOCHECKBOX "Waktu untuk menampilkan opsi pemulihan bila diperlukan:", IDC_STRRECREC, 14, 70, 170, 8
    EDITTEXT IDC_STRRECRECEDIT, 185, 68, 30, 12, ES_NUMBER
    CONTROL "", IDC_STRRECRECUPDWN, "msctls_updown32", UDS_WRAP | UDS_SETBUDDYINT |
            UDS_ALIGNRIGHT | UDS_AUTOBUDDY | UDS_ARROWKEYS | UDS_NOTHOUSANDS | WS_CHILD | WS_VISIBLE, 0, 0, 8, 13
    LTEXT "detik", IDC_STATIC, 223, 70, 18, 8
    LTEXT "Untuk mengedit file opsi startup secara manual, klik Edit.", IDC_STATIC, 14, 89, 187, 8
    PUSHBUTTON "&Edit", IDC_STRRECEDIT, 188, 87, 50, 14
    GROUPBOX "Kegagalan sistem", IDC_STATIC, 7, 111, 238, 140
    AUTOCHECKBOX "& Tulis sebuah acara ke log sistem", IDC_STRRECWRITEEVENT, 14, 124, 148, 10
    AUTOCHECKBOX "Menganggap siaga administratif", IDC_STRRECSENDALERT, 14, 138, 148, 10
    AUTOCHECKBOX "Otomatis & restart", IDC_STRRECRESTART, 14, 152, 145, 10
    GROUPBOX "Tulis informasi debug", IDC_STATIC, 12, 167, 227, 76
    COMBOBOX IDC_STRRECDEBUGCOMBO, 17, 182, 151, 49, CBS_DROPDOWNLIST
    LTEXT "Dump & file:", IDC_STATIC, 17, 202, 150, 8
    EDITTEXT IDC_STRRECDUMPFILE, 17, 210, 153, 12, ES_AUTOHSCROLL
    AUTOCHECKBOX "& Timpa file yang ada", IDC_STRRECOVERWRITE, 17, 228, 125, 10
    DEFPUSHBUTTON "Oke", IDOK, 141, 259, 50, 14
    PUSHBUTTON "Membatalkan", IDCANCEL, 195, 259, 50, 14
END

IDD_VIRTMEM DIALOGEX 6, 6, 223, 248
STYLE DS_SHELLFONT | DS_MODALFRAME | DS_CONTEXTHELP | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "Memori Virtual"
FONT 8, "MS Shell Dlg", 0, 0, 0x0
BEGIN
