    COMBOBOX 1081, 115, 146, 60, 100, CBS_DROPDOWNLIST | WS_VSCROLL | NOT WS_TABSTOP
    LTEXT "D&uration at least:", 1087, 16, 168, 92, 8, NOT WS_GROUP
