LANGUAGE LANG_INDONESIAN, SUBLANG_INDONESIAN_INDONESIA

102 DIALOGEX 0, 0, 255, 265
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUPWINDOW | WS_CAPTION
CAPTION "Alternate Phone Numbers"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Tentukan nomor telepon alternatif yang ingin Anda gunakan untuk membuat koneksi ini.", 1018, 7, 5, 243, 16
    LTEXT "&Nomor telepon:", 1019, 7, 27, 238, 8
    CONTROL "", 1012, "SYSLISTVIEW32", WS_BORDER | WS_TABSTOP | 0x0000848D, 7, 38, 217, 144
    PUSHBUTTON "Pindahkan &naik", 1017, 230, 40, 18, 16, BS_ICON
    PUSHBUTTON "Pindahkan &turun", 1015, 230, 61, 18, 16, BS_ICON
    PUSHBUTTON "&Tambah...", 1013, 7, 187, 70, 14
    PUSHBUTTON "Edit...", 1016, 81, 187, 70, 14
    PUSHBUTTON "&Menghapus", 1014, 154, 187, 70, 14
    AUTOCHECKBOX "Jika &nomor gagal, coba nomor berikutnya", 1011, 8, 210, 243, 10, BS_TOP | BS_MULTILINE
    AUTOCHECKBOX "&Pindahkan nomor yang berhasil ke daftar teratas", 1010, 8, 228, 243, 10, BS_TOP | BS_MULTILINE
    DEFPUSHBUTTON "Oke", 1, 122, 245, 60, 14
    PUSHBUTTON "Membatalkan", 2, 188, 245, 60, 14
END

103 DIALOGEX 6, 18, 250, 170
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION
CAPTION "Koneksi jaringan"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "", 1029, 5, 5, 241, 35, NOT WS_GROUP
    LTEXT "C&onnections:", -1, 5, 46, 238, 10
    CONTROL "Daftar1", 1677, "SYSLISTVIEW32", WS_BORDER | WS_TABSTOP | 0x0000440D, 5, 57, 240, 57
    AUTOCHECKBOX "&Jangan tanya saya lagi sampai lain kali saya log on", 1022, 8, 125, 235, 10
    PUSHBUTTON "&Setelan", 1026, 7, 149, 60, 14
    DEFPUSHBUTTON "&Menghubungkan...", 1024, 117, 149, 60, 14
    PUSHBUTTON "Membatalkan", 1025, 183, 149, 60, 14
END

104 DIALOGEX 6, 18, 269, 263
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUPWINDOW | WS_VISIBLE | WS_CAPTION
CAPTION "Line Bundling Errors"
FONT 8, "MS Shell Dlg"
BEGIN
    ICON 32516, 1031, 7, 7, 20, 20
    LTEXT "Satu atau lebih baris tambahan tidak terhubung. ", 1033, 37, 8, 216, 20
    CONTROL "", 1032, "SYSLISTVIEW32", WS_BORDER | WS_TABSTOP | 0x00008401, 37, 83, 224, 136
    AUTOCHECKBOX "&Jangan mencoba baris yang gagal di masa depan", 1030, 38, 226, 222, 10
    DEFPUSHBUTTON "&Menerima", 1, 135, 242, 60, 14
    PUSHBUTTON "&Tutup Telepon", 2, 201, 242, 60, 14
    LTEXT "Jika hanya satu baris terhubung, server mungkin tidak dikonfigurasi untuk menerima panggilan multi-link. Periksa 'Jangan mencoba baris yang gagal' untuk menghindari biaya koneksi yang tidak perlu dalam kasus seperti itu.", -1, 37, 36, 224, 44
END

105 DIALOGEX 0, 0, 261, 253
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUPWINDOW | WS_CAPTION
CAPTION "Advanced Security Settings"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Keamanan logon", 1547, 7, 33, 246, 191
    LTEXT "&Enkripsi data:", 1546, 7, 5, 247, 10
    COMBOBOX 1495, 7, 17, 247, 76, CBS_DROPDOWNLIST | WS_VSCROLL | NOT WS_TABSTOP
    AUTORADIOBUTTON "Use &Extensible Authentication Protocol (EAP)", 1544, 17, 47, 226, 8, WS_GROUP
    LTEXT "Tipe EAP", -1, 18, 64, 35, 8, NOT WS_VISIBLE | NOT WS_GROUP
    COMBOBOX 1034, 53, 62, 191, 42, CBS_DROPDOWNLIST | CBS_SORT | WS_VSCROLL | NOT WS_TABSTOP
    PUSHBUTTON "P&roperties", 1035, 184, 77, 60, 14
    AUTORADIOBUTTON "Izinkan &protokol ini", 1545, 17, 92, 224, 10
    AUTOCHECKBOX "&Sandi yang tidak terenkripsi (PAP)", 1491, 28, 105, 215, 10, BS_TOP | BS_MULTILINE | WS_GROUP
    AUTOCHECKBOX "&Shiva Password Authentication Protocol (SPAP)", 1496, 28, 119, 214, 10, BS_TOP | BS_MULTILINE
    AUTOCHECKBOX "&Tantangan Handshake Authentication Protocol (CHAP)", 1494, 28, 133, 215, 10, BS_TOP | BS_MULTILINE
    AUTOCHECKBOX "&MS CHAP (MS-CHAP)", 1493, 28, 148, 212, 10, BS_TOP | BS_MULTILINE
    AUTOCHECKBOX "Izinkan versi MS-CHAP yang lebih lawas untuk &Win 95 server", 200, 46, 162, 198, 10, BS_TOP | BS_MULTILINE
    AUTOCHECKBOX "M&icrosoft CHAP Versi 2 (MS-CHAP v2)", 1492, 28, 176, 200, 10, BS_TOP | BS_MULTILINE
    CONTROL "", -1, "STATIC", SS_LEFTNOWORDWRAP | SS_SUNKEN | WS_GROUP, 28, 189, 208, 1
    AUTOCHECKBOX "&Untuk protokol berbasis MS-CHAP, gunakan nama dan kata sandi ReactOS saya secara otomatis (dan domain jika ada)", 1549, 28, 195, 213, 24, BS_TOP | BS_MULTILINE
    DEFPUSHBUTTON "Oke", 1, 127, 232, 60, 14
    PUSHBUTTON "Membatalkan", 2, 192, 232, 60, 14
END

106 DIALOGEX 6, 18, 255, 109
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUPWINDOW | WS_VISIBLE | WS_CAPTION
