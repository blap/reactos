BEGIN
    IDS_TYPETITLE "Selamat datang di Setup ReactOS"
    IDS_TYPESUBTITLE "Pilih jenis setup."
    IDS_DEVICETITLE "Setup perangkat dasar"
    IDS_DEVICESUBTITLE "Atur pengaturan tampilan dan keyboard."
    IDS_DRIVETITLE "Setup partisi instalasi dan folder sistem"
    IDS_DRIVESUBTITLE "Siapkan partisi instalasi, folder sistem dan boot loader."
    IDS_PROCESSTITLE "Setup partisi, copy file dan setup system"
    IDS_PROCESSSUBTITLE "Buat dan format partisi, copy file, install dan setup boot loader"
    IDS_RESTARTTITLE "Tahap pertama setup selesai"
    IDS_RESTARTSUBTITLE "Tahap pertama setup telah selesai, restart untuk melanjutkan tahap kedua"
    IDS_SUMMARYTITLE "Ringkasan Instalasi"
    IDS_SUMMARYSUBTITLE "Cantumkan properti penginstalan untuk diperiksa sebelum mendaftar ke perangkat penginstalan"
    IDS_ABORTSETUP "ReactOS tidak sepenuhnya terpasang di komputer Anda. Jika Anda keluar dari Setup sekarang, Anda perlu menjalankan Setup lagi untuk menginstal ReactOS. Benar-benar berhenti?"
    IDS_ABORTSETUP2 "Batalkan pemasangan?"
    IDS_NO_TXTSETUP_SIF "Tidak dapat menemukan 'txtsetup.sif'\nSetup tidak dapat dilanjutkan"
    IDS_CAPTION "Setup ReactOS"
END

