                    "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 5, 158, 203, 12
    LTEXT           "Harap dicatat bahwa beberapa layanan %s aman mungkin tidak dinonaktifkan.", IDC_STATIC_SERVICES_WARNING, 5, 138, 220, 17
END

