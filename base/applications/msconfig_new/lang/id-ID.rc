LANGUAGE LANG_INDONESIAN, SUBLANG_INDONESIAN_INDONESIA

IDD_ABOUTBOX DIALOGEX 0, 0, 229, 98
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Tentang Program Konfigurasi Sistem"
FONT 8, "MS Shell Dlg"
BEGIN
    ICON            IDI_APPICON, IDC_STATIC, 14, 14, 20, 20
    LTEXT           "Program Konfigurasi Sistem \n Versi 1.0", IDC_STATIC, 42, 14, 182, 17, SS_NOPREFIX
//  "Copyright (C) ReactOS Team 2005-"COPYRIGHT_YEAR"\n"
    LTEXT           "Copyright (C) ReactOS Team 2005-2015\n\
Christoph von Wittich (Christoph@ApiViewer.de)\n\
Gregor Schneider (Gregor.Schneider@reactos.org)\n\
Hermès BÉLUSCA - MAÏTO (hermes.belusca@sfr.fr)",
                    IDC_STATIC, 41, 34, 183, 34
    DEFPUSHBUTTON   "Oke", IDOK, 174, 79, 50, 14, WS_GROUP
END

IDD_GENERAL_PAGE DIALOGEX 0, 0, 366, 175
STYLE DS_SHELLFONT | DS_CONTROL | WS_CHILD | WS_CAPTION
CAPTION "Umum"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL         "&Startup Normal", IDC_RB_NORMAL_STARTUP, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 15, 18, 332, 10
    CONTROL         "&Diagnostik Startup", IDC_RB_DIAGNOSTIC_STARTUP, "Button", BS_AUTORADIOBUTTON, 15, 46, 332, 10
    CONTROL         "S&elektif Startup", IDC_RB_SELECTIVE_STARTUP, "Button", BS_AUTORADIOBUTTON, 15, 73, 332, 10
    CONTROL         "Proses File S&YSTEM.INI", IDC_CBX_SYSTEM_INI, "Button", BS_AUTO3STATE | WS_TABSTOP, 35, 86, 316, 10
    CONTROL         "Proses File &WIN.INI", IDC_CBX_WIN_INI, "Button", BS_AUTO3STATE | WS_TABSTOP, 35, 98, 316, 10
    CONTROL         "&Ambil Layanan Sistem", IDC_CBX_LOAD_SYSTEM_SERVICES, "Button", BS_AUTO3STATE | WS_TABSTOP, 35, 110, 316, 10
    CONTROL         "Amb&il Item Startup", IDC_CBX_LOAD_STARTUP_ITEMS, "Button", BS_AUTO3STATE | WS_TABSTOP, 35, 122, 316, 10
    CONTROL         "&Gunakan konfigurasi boot asli", IDC_CBX_USE_ORIGINAL_BOOTCFG, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 35, 134, 316, 10
    PUSHBUTTON      "Pemulihan Sistem Laun&ch", IDC_BTN_SYSTEM_RESTORE_START, 146, 156, 124, 14
    PUSHBUTTON      "&Perluas Berkas...", IDC_BTN_FILE_EXTRACTION, 275, 156, 85, 14
    GROUPBOX        "Pilihan Startup", IDC_STATIC, 5, 5, 356, 145
    LTEXT           "Mengambil semua device drivers dan layanan", IDC_STATIC, 25, 30, 322, 10
    LTEXT           "Mengambil hanya devices dan layanan dasar", IDC_STATIC, 25, 58, 322, 10
END

IDD_SYSTEM_PAGE DIALOGEX 0, 0, 366, 175
