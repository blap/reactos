    PUSHBUTTON      "Pindahkan naik", IDC_BTN_SYSTEM_UP, 295, 5, 66, 14
    PUSHBUTTON      "Pindah & Turunkan", IDC_BTN_SYSTEM_DOWN, 295, 24, 66, 14
    PUSHBUTTON      "&Memungkinkan", IDC_BTN_SYSTEM_ENABLE, 295, 52, 66, 14
    PUSHBUTTON      "Menonaktifkan", IDC_BTN_SYSTEM_DISABLE, 295, 71, 66, 14
    PUSHBUTTON      "&Menemukan", IDC_BTN_SYSTEM_FIND, 295, 99, 66, 14
    PUSHBUTTON      "&Baru", IDC_BTN_SYSTEM_NEW, 295, 118, 66, 14
    PUSHBUTTON      "Edit", IDC_BTN_SYSTEM_EDIT, 295, 137, 66, 14
    PUSHBUTTON      "Ena&ble Semua", IDC_BTN_SYSTEM_ENABLE_ALL, 153, 156, 66, 14
    PUSHBUTTON      "Menonaktifkan semua", IDC_BTN_SYSTEM_DISABLE_ALL, 224, 156, 66, 14
    PUSHBUTTON      "Hapus", IDC_BTN_SYSTEM_DELETE, 295, 156, 66, 14
END

IDD_FREELDR_PAGE DIALOGEX 0, 0, 366, 175
STYLE DS_SHELLFONT | DS_CONTROL | WS_CHILD | WS_CAPTION
CAPTION "FREELDR.INI"
FONT 8, "MS Shell Dlg"
BEGIN
    LISTBOX         IDC_LIST_BOX, 5, 5, 356, 61, LBS_HASSTRINGS | LBS_NOINTEGRALHEIGHT | WS_VSCROLL | WS_HSCROLL | WS_TABSTOP
    PUSHBUTTON      "Periksa semua jalur boot", IDC_BTN_CHECK_BOOT_PATH, 5, 68, 72, 14
    PUSHBUTTON      "Ditetapkan &sebagai default", IDC_BTN_SET_DEFAULT_BOOT, 82, 68, 66, 14
    PUSHBUTTON      "Pindahkan naik", IDC_BTN_MOVE_UP_BOOT_OPTION, 153, 68, 66, 14
    PUSHBUTTON      "Pindah & Turunkan", IDC_BTN_MOVE_DOWN_BOOT_OPTION, 224, 68, 66, 14
    GROUPBOX        "Pilihan Boot", IDC_STATIC, 5, 84, 285, 86
    GROUPBOX        "", IDC_STATIC, 10, 97, 143, 68
    CHECKBOX        "Boot aman (/SA&FEBOOT)", IDC_CBX_SAFE_BOOT, 15, 97, 121, 10
    CONTROL         "Minimal (& MINIMAL)", IDC_RADIO1, "Button", BS_AUTORADIOBUTTON, 15, 110, 133, 10
    CONTROL         "Lingkungan lain\n (M&INIMAL (ALTERNATESHELL))", IDC_RADIO4,
                    "Button", BS_AUTORADIOBUTTON | BS_MULTILINE, 15, 121, 133, 17
    CONTROL         "Perbaikan ActiveDirectory (DSRE & PAIR)", IDC_RADIO3, "Button", BS_AUTORADIOBUTTON, 15, 139, 133, 10
    CONTROL         "Jaringan (NET & WORK)", IDC_RADIO2, "Button", BS_AUTORADIOBUTTON, 15, 150, 133, 10
    CHECKBOX        "Tidak ada boot GUI\n (/&NOGUIBOOT)", IDC_CBX_NO_GUI_BOOT, 158, 91, 127, 17, BS_MULTILINE
    CHECKBOX        "Boot log (/& BOOTLOG)", IDC_CBX_BOOT_LOG, 158, 110, 127, 12
    CHECKBOX        "Video dasar (/BAS & EVIDEO)", IDC_CBX_BASE_VIDEO, 158, 124, 127, 12
    CHECKBOX        "Informasi booting OS (/S&OS)", IDC_CBX_SOS, 158, 138, 127, 12
    PUSHBUTTON      "Opsi iklan &vanced...", IDC_BTN_ADVANCED_OPTIONS, 207, 151, 78, 14
    LTEXT           "&Waktu habis:", IDC_STATIC, 296, 91, 32, 10
    EDITTEXT        IDC_TXT_BOOT_TIMEOUT, 295, 102, 33, 12, ES_RIGHT | ES_NUMBER
    LTEXT           "detik", IDC_STATIC, 330, 104, 31, 10
    CONTROL         "Membu&at semua pengaturan boot permanen", 292,
                    "Button", BS_AUTOCHECKBOX | BS_TOP | BS_MULTILINE | WS_TABSTOP, 295, 121, 66, 49
    PUSHBUTTON      "&Menghapus", IDC_BTN_DELETE, 295, 68, 66, 14
END

IDD_SERVICES_PAGE DIALOGEX 0, 0, 366, 175
STYLE DS_SHELLFONT | DS_CONTROL | WS_CHILD | WS_CAPTION
