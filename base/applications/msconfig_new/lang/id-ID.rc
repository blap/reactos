    PUSHBUTTON      "&Aktifkan semua", IDC_BTN_SERVICES_ACTIVATE, 224, 156, 66, 14
    PUSHBUTTON      "&Deaktivasi semua", IDC_BTN_SERVICES_DEACTIVATE, 295, 156, 66, 14
