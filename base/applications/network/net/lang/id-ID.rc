LANGUAGE LANG_INDONESIAN, SUBLANG_INDONESIAN_INDONESIA

STRINGTABLE
BEGIN
    IDS_ACCOUNTS_SYNTAX "Usage:\nNET ACCOUNTS [/FORCELOGOFF:{Minutes|NO}] [/MINPWLEN:Length]\n\
             [/MAXPWAGE:{Days|UNLIMITED}] [/MINPWAGE:Days]\n\
             [/UNIQUEPW:Count] [/DOMAIN]\n"
    IDS_ACCOUNTS_HELP "ACCOUNTS \n..."
    IDS_COMPUTER_SYNTAX "Penggunaan: \nNET COMPUTER ..."
    IDS_COMPUTER_HELP "KOMPUTER \n..."
    IDS_CONFIG_SYNTAX "Penggunaan: \nNET CONFIG ..."
    IDS_CONFIG_HELP "CONFIG\n..."
    IDS_CONTINUE_SYNTAX "Penggunaan: \nNET LANJUTKAN <Nama Layanan>"
    IDS_CONTINUE_HELP "LANJUTKAN \n..."
    IDS_FILE_SYNTAX "Penggunaan: \nNET FILE ..."
    IDS_FILE_HELP "FILE\n..."
    IDS_GROUP_SYNTAX "Penggunaan: \nNET GROUP ..."
    IDS_GROUP_HELP "GROUP \n..."
    IDS_HELPMSG_SYNTAX "Gunakan: \nNET HELPMSG <Error Code>"
    IDS_HELPMSG_HELP "HELPMSG \n..."
    IDS_LOCALGROUP_SYNTAX "Gunakan: \nNET LOCALGROUP [nama grup [/COMMENT: """teks"""]]"]] [/DOMAIN]\n\
               groupname {/ADD [/COMMENT:""text""] | /DELETE} [/DOMAIN]\n\
               groupname name [...] {/ADD | /DELETE} [/DOMAIN]"
    IDS_LOCALGROUP_HELP "LOCALGROUP\n..."
    IDS_NAME_SYNTAX "Penggunaan:\nNET NAME ..."
    IDS_NAME_HELP "NAME \n..."
    IDS_PRINT_SYNTAX  "Penggunaan: \nNET PRINT ..."
    IDS_PRINT_HELP "PRINT \n..."
    IDS_PAUSE_SYNTAX "Penggunaan: \nNET PAUSE <Service Name>"
    IDS_PAUSE_HELP "PAUSE \n..."
    IDS_SEND_SYNTAX "Gunakan: \nNET SEND ..."
    IDS_SEND_HELP "SEND\n..."
    IDS_SESSION_SYNTAX "Gunakan: \nNET SESI ..."
    IDS_SESSION_HELP "SESI\n..."
    IDS_SHARE_SYNTAX "Gunakan:\nNET SAHAM ..."
    IDS_SHARE_HELP "BERBAGI\n..."
    IDS_START_SYNTAX "Bijak: \nNET START <nama layanan>"
    IDS_START_HELP "Mulai \n..."
    IDS_STATISTICS_SYNTAX "Penggunaan: \nNET STATISTIK ..."
    IDS_STATISTICS_HELP "STATISTIK \n..."
    IDS_STOP_SYNTAX "Gunakan: \nNET STOP <Service nama>"
    IDS_STOP_HELP "STOP \n..."
    IDS_TIME_SYNTAX "Penggunaan: \nNET TIME ..."
    IDS_TIME_HELP "WAKTU\n..."
    IDS_USE_SYNTAX "Penggunaan: \nNET USE ..."
    IDS_USE_HELP "USE \n..."
    IDS_USER_SYNTAX "Usage:\nNET USER [username [password | *] [options]] [/DOMAIN]\n\
         username {password | *} /ADD [options] [/DOMAIN]\n\
         username [/DELETE] [/DOMAIN]"
    IDS_USER_HELP "USER \n..."
    IDS_VIEW_SYNTAX "Gunakan: \nNET LIHAT ..."
    IDS_VIEW_HELP "LIHAT \n..."
    IDS_HELP_SYNTAX "Usage:\nNET HELP <Command>\n   - or -\nNET <Command> /HELP\n\n\
   The following commands are available:\n\n\
   NET ACCOUNTS             NET HELP                 NET SHARE\n\
   NET COMPUTER             NET HELPMSG              NET START\n\
   NET CONFIG               NET LOCALGROUP           NET STATISTICS\n\
   NET CONFIG SERVER        NET NAME                 NET STOP\n\
   NET CONFIG WORKSTATION   NET PAUSE                NET TIME\n\
   NET CONTINUE             NET PRINT                NET USE\n\
   NET FILE                 NET SEND                 NET USER\n\
   NET GROUP                NET SESSION              NET VIEW\n\n\
   ..."
    IDS_NET_SYNTAX "Usage:\nNET [ ACCOUNTS | COMPUTER | CONFIG | CONTINUE | FILE | GROUP | HELP |\n\
      HELPMSG | LOCALGROUP | NAME | PAUSE | PRINT | SEND | SESSION |\n\
      SHARE | START | STATISTICS | STOP | TIME | USE | USER | VIEW ]\n"

    IDS_ACCOUNTS_FORCE_LOGOFF "Pakai logoff setelahnya"
    IDS_ACCOUNTS_LOGOFF_SECONDS "%lu detik"
    IDS_ACCOUNTS_MIN_PW_AGE "Usia sandi minimum (dalam hitungan hari)"
    IDS_ACCOUNTS_MAX_PW_AGE "Usia sandi maksimum (dalam hitungan hari)"
    IDS_ACCOUNTS_MIN_PW_LENGTH "Panjang kata sandi minimum"
    IDS_ACCOUNTS_PW_HIST_LENGTH "Panjang riwayat kata sandi"
    IDS_ACCOUNTS_LOCKOUT_THRESHOLD "Ambang lockout"
    IDS_ACCOUNTS_LOCKOUT_DURATION "Durasi penguncian (dalam menit)"
