    IDS_ACCOUNTS_BACKUP_SERVER "Server cadangan"
    IDS_ACCOUNTS_STANDALONE_SERVER "Server standalone"
    IDS_ACCOUNTS_WORKSTATION "Workstation"

    IDS_LOCALGROUP_ALIASES "Alias untuk \\\\%s"
    IDS_LOCALGROUP_ALIAS_NAME "Nama alias"
    IDS_LOCALGROUP_COMMENT "Komentar"
    IDS_LOCALGROUP_MEMBERS "Anggota"

    IDS_USER_ACCOUNTS "Akun pengguna untuk \\\\%s"
    IDS_USER_NAME "Nama pengguna"
    IDS_USER_FULL_NAME "Nama Penuh"
    IDS_USER_COMMENT "Komentar"
    IDS_USER_USER_COMMENT "Komentar pengguna"
    IDS_USER_COUNTRY_CODE "Kode negara"
    IDS_USER_ACCOUNT_ACTIVE "Akun aktif"
    IDS_USER_ACCOUNT_EXPIRES "Akun berakhir"
    IDS_USER_PW_LAST_SET "Password set terakhir"
    IDS_USER_PW_EXPIRES "Password kadaluarsa"
    IDS_USER_PW_CHANGEABLE "Password berubah"
    IDS_USER_PW_REQUIRED "Password diperlukan"
    IDS_USER_CHANGE_PW "Pengguna bisa mengganti password"
    IDS_USER_WORKSTATIONS "Workstation diperbolehkan"
    IDS_USER_LOGON_SCRIPT "Script logon"
    IDS_USER_PROFILE "Profil pengguna"
    IDS_USER_HOME_DIR "Direktori rumah"
    IDS_USER_LAST_LOGON "Logon terakhir"
    IDS_USER_LOGON_HOURS "Jam logon diizinkan"
    IDS_USER_LOCAL_GROUPS "Keanggotaan kelompok lokal"
    IDS_USER_GLOBAL_GROUPS "Keanggotaan kelompok global"

    IDS_USER_ENTER_PASSWORD1 "Masukkan kata sandi baru untuk pengguna: "
    IDS_USER_ENTER_PASSWORD2 "Masukkan kata sandi lagi: "
    IDS_USER_NO_PASSWORD_MATCH "Kata sandi tidak cocok!"

    IDS_USE_NOW_CONNECTED "%s sekarang terhubung ke%s \n"

    IDS_GENERIC_YES "Iya"
    IDS_GENERIC_NO "Tidak"
    IDS_GENERIC_NEVER "Never"
    IDS_GENERIC_NONE "Tidak ada"
    IDS_GENERIC_ALL "GENERIC_ALL"
    IDS_GENERIC_LOCKED "Terkunci"

    IDS_ERROR_OPTION_NOT_SUPPORTED "Opsi %s belum didukung. \n"
    IDS_ERROR_INVALID_OPTION_VALUE "Anda memasukkan nilai yang tidak valid untuk opsi %s.\n"
    IDS_ERROR_SYSTEM_ERROR "Kesalahan sistem %d terjadi.\n"
    IDS_ERROR_NO_ERROR "Perintah berhasil dijalankan.\n"
