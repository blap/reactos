LANGUAGE LANG_INDONESIAN, SUBLANG_INDONESIAN_INDONESIA

IDR_MAINMENU MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "Buka... \tCtrl + &O", IDM_OPEN_FILE
        MENUITEM "&Tutup\tCtrl+W", IDM_CLOSE_FILE
        MENUITEM SEPARATOR
        MENUITEM "&Keluar", IDM_EXIT
    END
    POPUP "&Main"
    BEGIN
        MENUITEM "Mainkan/&Jeda\tCtrl + P", IDC_PLAY
        MENUITEM "Berhenti\t
Ctrl+ S", IDC_STOP
        MENUITEM SEPARATOR
        MENUITEM "Ulangi\Ctrl+T", IDM_REPEAT
    END
    POPUP "&Lihat"
    BEGIN
        MENUITEM "Satu jendela & Mode", IDM_SWITCHVIEW
    END
    POPUP "Perangkat"
    BEGIN
        MENUITEM SEPARATOR
        MENUITEM "Properti", IDM_DEVPROPS
        MENUITEM SEPARATOR
        MENUITEM "Pengatur Suara", IDM_VOLUMECTL
    END
    POPUP "&File"
    BEGIN
        MENUITEM "&Tentang", IDM_ABOUT
    END
END

ID_ACCELERATORS ACCELERATORS
BEGIN
    "^O", IDM_OPEN_FILE
    "^W", IDM_CLOSE_FILE
    "^P", IDC_PLAY
    "^S", IDC_STOP
    "^T", IDM_REPEAT
END

