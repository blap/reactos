    IDS_TOOLTIP_SEEKBACK "Pencarian Mundur"
    IDS_TOOLTIP_SEEKFORW "Pencarian Depan"
    IDS_TOOLTIP_FORWARD "Loncat Ke Depan"
    IDS_TOOLTIP_PAUSE "Istirahat"
