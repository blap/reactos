    GROUPBOX "Fitur ReactX", IDC_STATIC, 5, 97, 452, 70
    CONTROL "", IDC_SLIDER_DSOUND, "msctls_trackbar32", TBS_BOTTOM | TBS_AUTOTICKS | WS_TABSTOP, 110, 125, 80, 17
    RTEXT "Suara Perangkat Keras \ N Level Percepatan:", IDC_STATIC, 10, 125, 90, 20, WS_DISABLED
    PUSHBUTTON "Uji Suara Langsung", IDC_BUTTON_TESTDSOUND, 270, 125, 80, 14, WS_DISABLED
    GROUPBOX "Catatan", IDC_STATIC, 5, 170, 452, 50
