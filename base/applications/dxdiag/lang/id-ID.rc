IDD_HELP_DIALOG DIALOGEX 0, 0, 462, 220
STYLE DS_SHELLFONT | DS_CONTROL | WS_CHILD | WS_CLIPCHILDREN
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Masih belum dapat menemukan informasi yang anda cari? Berikut beberapa hal tambahan yang dapat anda lakukan:", IDC_STATIC, 5, 0, 300, 10
    PUSHBUTTON "Informasi Sistem", IDC_BUTTON_SYSINFO, 5, 20, 80, 14, WS_DISABLED
