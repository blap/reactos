    PUSHBUTTON "Menyegarkan Menilai Mengesampingkan", IDC_BUTTON_DDRAW_REFRESH, 5, 40, 80, 14, WS_DISABLED
    LTEXT "Mengesampingkan Nilai Menyegarkan untuk DirectDraw", IDC_STATIC, 90, 43, 300, 10
END

