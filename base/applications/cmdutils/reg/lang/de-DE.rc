    STRING_REG_HELP, "Type ""REG /?"" for help.\n"
    STRING_FUNC_HELP, "Type ""REG %1 /?"" for help.\n"
    STRING_VALUE_NOT_SET, "(Wert nicht gesetzt)"
    STRING_IMPORT_USAGE, "REG IMPORT file.reg\n"
    STRING_FILE_NOT_FOUND, "reg: Die Datei '%1' wurde nicht gefunden.\n"
    STRING_OPEN_KEY_FAILED, "reg: Konnte den Registry Schlpssel '%1' nicht öffnen.\n"
