    STRING_NO, "N"
    STRING_CANCELLED, "Der Registryvorgang wurde abgebrochen\n"
    STRING_DEFAULT_VALUE, "(Standard)"
    STRING_DELETE_VALUE, "Registry Wert '%1' wirklich löschen'?"
    STRING_DELETE_VALUEALL, "Alle Registry Werte in '%1' wirklich löschen'?"
    STRING_DELETE_SUBKEY, "Registry Schlüssel '%1' wirklich löschen'?"
    STRING_INVALID_STRING, "reg: Der Option [/d] muss eine gültige Zeichenkette folgen\n"
    STRING_VALUEALL_FAILED, "reg: Konnte nicht alle Registry Werte in '%1' löschen. Ein unerwarteter Fehler ist aufgetreten.\n"
    STRING_GENERAL_FAILURE, "reg: Der angegebene Vorgang kann nicht abgeschlossen werden. Ein unerwarteter Fehler ist aufgetreten.\n"
    STRING_MATCHES_FOUND, "Suche abgeschlossen. Anzahl gefundener Übereinstimmungen: %1!d!\n"
    STRING_INVALID_SYNTAX, "reg: Ungültige syntax. "
